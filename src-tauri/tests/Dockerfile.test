FROM rust:1.86-bookworm

WORKDIR /app

# Install system dependencies for building
RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    libsqlite3-dev \
    libgtk-3-dev \
    libwebkit2gtk-4.1-dev \
    libayatana-appindicator3-dev \
    librsvg2-dev \
    && rm -rf /var/lib/apt/lists/*

# Copy source
COPY . .

# Build tests only (faster than building the full app)
RUN cargo test --test peer_storage_e2e --no-run 2>&1 | tail -5

# Run the E2E tests
CMD ["cargo", "test", "--test", "peer_storage_e2e", "--", "--nocapture"]
