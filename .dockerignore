# Keeps the Docker build context small when this repo is mounted as
# `local-vault` by haex-e2e-tests. Without it the 14+ GB `src-tauri/target`
# directory is transferred to the build daemon on every docker build.

# Rust build output — regenerated inside the container.
src-tauri/target/

# Node / pnpm — regenerated by `pnpm install` inside the container.
node_modules/
**/node_modules/
.pnpm-store/

# Nuxt build output — regenerated by `pnpm generate` inside the container.
.nuxt/
.output/

# Tauri Android build output.
src-tauri/gen/
src-tauri/.cargo/

# IDE / OS noise — irrelevant for the build.
.vscode/
.idea/
.DS_Store

# Test artefacts — not needed for a production build.
test-results/
playwright-report/
coverage/
